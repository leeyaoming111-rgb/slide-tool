{
  "$meta": {
    "name": "case-design-system",
    "version": "0.2.0",
    "owner": "Yao Ming",
    "purpose": "Reusable MBB-standard slide components for case competitions, finance-weighted.",
    "note": "Two visual families share one foundation. 'corporate' is the default (clean, boardroom). 'activist' is an optional high-contrast mode seen in the Irenic references."
  },
  "color": {
    "ink":        { "value": "#14233A", "use": "Headline text, darkest emphasis." },
    "navy":       { "value": "#1F3A52", "use": "Primary bars, table headers, primary fills." },
    "navyDeep":   { "value": "#163041", "use": "Darker accent column / emphasis header." },
    "accent":     { "value": "#2E6FB0", "use": "Single highlight blue. Use sparingly on the hero element." },
    "blueMid":    { "value": "#5B8FC7", "use": "Secondary series in stacked charts." },
    "blueLight":  { "value": "#A9C4DD", "use": "Tertiary series / light fills." },
    "slate":      { "value": "#5B6B79", "use": "Source lines, secondary labels." },
    "gridline":   { "value": "#C9D2DA", "use": "Axis lines, faint gridlines, dividers." },
    "panel":      { "value": "#F4F6F7", "use": "Light panel / exhibit background." },
    "positive":   { "value": "#2E8B6F", "use": "Gains, upside, 'good' deltas." },
    "positiveBg": { "value": "#C9E7D6", "use": "Highlight fill behind a positive figure." },
    "negative":   { "value": "#C0473E", "use": "Declines, downside, risk." },
    "negativeBg": { "value": "#F3D8D5", "use": "Light tint behind a negative figure." },
    "caution":    { "value": "#E0A13C", "use": "Caution, reference/current-price lines." },
    "cautionBg":  { "value": "#F7E8CC", "use": "Light tint behind a caution figure." },
    "white":      { "value": "#FFFFFF", "use": "On-navy text, segment dividers." }
  },
  "colorActivist": {
    "black":   { "value": "#111111", "use": "Primary bars and headlines in activist mode." },
    "signal":  { "value": "#F5E003", "use": "Hero accent: endpoint bars, numbered chips, key uplift." }
  },
  "colorAliases": {
    "textTitle":    { "value": "ink" },
    "textBody":     { "value": "ink" },
    "textMuted":    { "value": "slate" },
    "textOnFill":   { "value": "white" },
    "surfacePage":  { "value": "white" },
    "surfacePanel": { "value": "panel" },
    "fillPrimary":  { "value": "navy" },
    "fillDeep":     { "value": "navyDeep" },
    "hero":         { "value": "accent" },
    "borderFaint":  { "value": "gridline" },
    "axis":         { "value": "gridline" },
    "bear":         { "value": "negative", "use": "ScenarioTable bear column header (fixed mapping)." },
    "base":         { "value": "accent",   "use": "ScenarioTable base column header (fixed mapping)." },
    "bull":         { "value": "positive", "use": "ScenarioTable bull column header (fixed mapping)." },
    "activistOverrides": {
      "note": "Under data-theme=\"activist\": textTitle/textBody -> black, fillPrimary/fillDeep -> black, hero -> signal.",
      "textTitle": "black", "textBody": "black", "fillPrimary": "black", "fillDeep": "black", "hero": "signal"
    }
  },
  "type": {
    "fontStack":  "Inter, Arial, sans-serif",
    "fontSerif":  "'Source Serif 4', Georgia, serif",
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "black": 800 },
    "lineHeights": { "tight": 1.1, "snug": 1.25, "normal": 1.45 },
    "scale": {
      "actionTitle": { "size": 22, "weight": 700, "color": "ink", "use": "The slide's one-sentence message." },
      "kicker":      { "size": 12, "weight": 600, "color": "navy", "tracking": 1.2, "transform": "uppercase", "use": "Section/category label before the title." },
      "chartTitle":  { "size": 15, "weight": 700, "color": "ink" },
      "label":       { "size": 13, "weight": 500, "color": "navy", "use": "Direct data and axis-category labels." },
      "value":       { "size": 12, "weight": 600, "color": "ink", "use": "Numbers on/near marks." },
      "axis":        { "size": 11, "weight": 400, "color": "slate" },
      "source":      { "size": 10, "weight": 400, "color": "slate", "style": "italic" },
      "bigNumber":   { "size": 40, "weight": 800, "color": "ink", "use": "The one loud figure on a KPI tile or exhibit." }
    }
  },
  "space": {
    "unit": 4, "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48],
    "gutter": 16, "panelPad": 20, "slideMargin": 48, "barCorner": 3,
    "radius": { "sm": 3, "md": 6, "lg": 10 },
    "borderHairline": 1, "ruleThick": 4
  },
  "canvas": { "slide": { "w": 960, "h": 540 }, "note": "16:9 working frame. Components export at their own native size for paste." }
}
